---
import Layout from '../layouts/Layout.astro';
import PawParticles from '../components/PawParticles';
import PetGigi from '../components/PetGigi';
import TreatCounter from '../components/TreatCounter';
import FunPoliceBadge from '../components/FunPoliceBadge';
---

<Layout>
  <PawParticles client:load />

  <section class="relative z-10 flex min-h-screen flex-col items-center justify-center px-6">
    <div class="flex w-full max-w-6xl flex-col items-center gap-12 md:flex-row md:gap-16">
      <div class="relative w-full max-w-lg md:w-[60%]">
        <img
          src="/images/gigi.jpg"
          alt="Gigi - Chief of the Fun Police"
          class="h-[26rem] w-full rounded-2xl object-cover shadow-2xl shadow-black/50 md:h-[34rem]"
        />
        <div class="absolute inset-0 rounded-2xl ring-1 ring-inset ring-white/10"></div>
      </div>

      <div class="flex flex-col items-center text-center md:items-start md:text-left">
        <p class="mb-4 font-mono text-xs tracking-[0.4em] uppercase text-cream/30 animate-pulse">
          🐾 WOOF
        </p>
        <h1
          class="mb-4 font-mono text-5xl font-bold leading-tight tracking-tight text-cream md:text-7xl"
        >
          Hi, I'm <span class="text-gold">Gigi</span>!
        </h1>
        <p class="mb-6 font-mono text-lg tracking-widest text-cream/60 md:text-xl">
          Chief of the Fun Police 🚨
        </p>
        <p class="max-w-sm font-sans text-sm leading-relaxed text-cream/40">
          Professional fun-stopper. Lap-sitter extraordinaire. Relentless chaser of squirrels and birds. On duty 24/7.
        </p>

        <a
          href="#interact"
          class="group mt-10 flex items-center gap-2 rounded-full border border-cream/10 bg-cream/5 px-6 py-3 font-mono text-xs tracking-wider text-cream/60 transition-all hover:border-gold/30 hover:bg-gold/10 hover:text-gold"
        >
          MEET GIGI
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform group-hover:translate-y-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
          </svg>
        </a>
      </div>
    </div>

    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-cream/20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </div>
  </section>

  <div class="pointer-events-none relative z-0">
    <div class="mx-auto h-px w-2/3 bg-gradient-to-r from-transparent via-cream/10 to-transparent"></div>
  </div>

  <section id="interact" class="relative z-10 flex min-h-screen flex-col items-center justify-center gap-16 px-6 py-20 md:flex-row md:gap-12">
    <div class="flex-1">
      <PetGigi client:load />
    </div>
    <div class="hidden h-48 w-px bg-gradient-to-b from-transparent via-cream/10 to-transparent md:block"></div>
    <div class="h-px w-48 bg-gradient-to-r from-transparent via-cream/10 to-transparent md:hidden"></div>
    <div class="flex-1">
      <TreatCounter client:load />
    </div>
  </section>

  <div class="pointer-events-none relative z-0">
    <div class="mx-auto h-px w-2/3 bg-gradient-to-r from-transparent via-siren-red/10 to-transparent"></div>
  </div>

  <FunPoliceBadge client:load />

  <footer class="relative z-10 border-t border-cream/5 py-8">
    <div class="mx-auto flex max-w-4xl flex-col items-center gap-4 px-6 md:flex-row md:justify-between">
      <p class="font-mono text-xs tracking-wider text-cream/20">
        &copy; Gigi Kumar Young &mdash; All rights reserved (and all fun stopped)
      </p>
      <p class="font-mono text-[10px] tracking-widest text-cream/10">
        BUILT WITH LOVE &amp; TREATS 🦴
      </p>
    </div>
  </footer>
</Layout>